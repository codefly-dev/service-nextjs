/**
 * Typed API client for backend REST endpoints.
 *
 * RULES:
 * - This file has ZERO React imports. It is fully testable with plain vitest.
 * - All response types are validated at runtime with Zod schemas.
 * - Works in both Server Components (async/await) and Client Components (via hooks).
 * - Auth token injection is configured via configureAPI().
 */

import { z } from "zod";

export interface APIConfig {
  baseUrl: string;
  getToken?: () => string | null;
}

let config: APIConfig = {
  baseUrl: process.env.NEXT_PUBLIC_BACKEND_URL || "http://localhost:8080",
};

export function configureAPI(c: Partial<APIConfig>) {
  config = { ...config, ...c };
}

export class APIError extends Error {
  constructor(
    public status: number,
    public body: unknown,
  ) {
    super(`API ${status}: ${typeof body === "string" ? body : JSON.stringify(body)}`);
    this.name = "APIError";
  }
}

async function request(path: string, options?: RequestInit): Promise<unknown> {
  const headers: Record<string, string> = {
    "Content-Type": "application/json",
  };

  const token = config.getToken?.();
  if (token) {
    headers["Authorization"] = `Bearer ${token}`;
  }

  const res = await fetch(`${config.baseUrl}${path}`, {
    ...options,
    headers: { ...headers, ...options?.headers },
  });

  if (!res.ok) {
    const body = await res.json().catch(() => res.statusText);
    throw new APIError(res.status, body);
  }

  const text = await res.text();
  return text ? JSON.parse(text) : {};
}

/**
 * GET with runtime type validation.
 */
export async function apiGet<T>(
  path: string,
  schema: z.ZodType<T>,
  params?: Record<string, string>,
): Promise<T> {
  const url = new URL(path, config.baseUrl);
  if (params) {
    Object.entries(params).forEach(([k, v]) => url.searchParams.set(k, v));
  }
  const data = await request(url.pathname + url.search);
  return schema.parse(data);
}

/**
 * POST with runtime type validation.
 */
export async function apiPost<T>(
  path: string,
  body: unknown,
  schema: z.ZodType<T>,
): Promise<T> {
  const data = await request(path, {
    method: "POST",
    body: JSON.stringify(body),
  });
  return schema.parse(data);
}

/**
 * DELETE request.
 */
export async function apiDelete(path: string): Promise<void> {
  await request(path, { method: "DELETE" });
}
