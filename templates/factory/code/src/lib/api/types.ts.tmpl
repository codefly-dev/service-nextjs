/**
 * API response types with Zod schemas for runtime validation.
 *
 * RULES:
 * - Every API response type has a corresponding Zod schema.
 * - Use z.infer<> to derive TypeScript types from schemas.
 * - Never manually write a type that duplicates a schema.
 *
 * If your backend generates OpenAPI types (via codefly proto companion),
 * import them here and wrap with Zod schemas for runtime safety.
 */

import { z } from "zod";

// Example: replace with your actual API types
export const ExampleItemSchema = z.object({
  id: z.string(),
  name: z.string(),
  createdAt: z.string().datetime().optional(),
});

export type ExampleItem = z.infer<typeof ExampleItemSchema>;

export const ExampleItemListSchema = z.array(ExampleItemSchema);
