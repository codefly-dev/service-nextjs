{{- if .WorkOS }}
import { withAuth, signOut } from "@workos-inc/authkit-nextjs";

// Re-export WorkOS auth helpers for use in server components.
// In server components: const { user } = await getUser();
// To sign out: call signOut() from a server action.
export async function getUser() {
  const { user } = await withAuth();
  return { user };
}

export { signOut };
{{- else }}
"use client";

import {
  createContext,
  useContext,
  useState,
  useCallback,
  useEffect,
  type ReactNode,
} from "react";
import { configureAPI, request } from "./api-client";

// ----------------------------------------------------------------
// Auth — wired to the codefly user-management AuthService.
// Stores JWT access token + refresh token in memory.
// Configures the API client with the token automatically.
//
// To swap to a different provider (NextAuth, Clerk, Supabase),
// replace the login/signup/logout implementations below.
// ----------------------------------------------------------------

type User = {
  id: string;
  name: string;
  email: string;
  avatar?: string;
};

type AuthContextType = {
  user: User | null;
  isLoading: boolean;
  isAuthenticated: boolean;
  login: (provider: string, providerId: string, email: string) => Promise<void>;
  signup: (provider: string, providerId: string, email: string, profile?: Record<string, string>) => Promise<void>;
  logout: () => Promise<void>;
  accessToken: string | null;
};

const AuthContext = createContext<AuthContextType | undefined>(undefined);

const TOKEN_KEY = "codefly_refresh_token";

export function AuthProvider({ children }: { children: ReactNode }) {
  const [user, setUser] = useState<User | null>(null);
  const [accessToken, setAccessToken] = useState<string | null>(null);
  const [isLoading, setIsLoading] = useState(true);

  // Configure API client to use the current token
  useEffect(() => {
    configureAPI({ getToken: () => accessToken });
  }, [accessToken]);

  // Try to restore session from refresh token on mount
  useEffect(() => {
    const refreshToken = localStorage.getItem(TOKEN_KEY);
    if (refreshToken) {
      request<{ access_token: string; refresh_token: string }>("/v1/auth/refresh", {
        method: "POST",
        body: JSON.stringify({ refresh_token: refreshToken }),
      })
        .then((resp) => {
          setAccessToken(resp.access_token);
          localStorage.setItem(TOKEN_KEY, resp.refresh_token);
          // Decode user from JWT claims (sub = user id)
          try {
            const payload = JSON.parse(atob(resp.access_token.split(".")[1]));
            setUser({ id: payload.sub, name: "", email: "", avatar: undefined });
          } catch {}
        })
        .catch(() => {
          localStorage.removeItem(TOKEN_KEY);
        })
        .finally(() => setIsLoading(false));
    } else {
      setIsLoading(false);
    }
  }, []);

  const login = useCallback(async (provider: string, providerId: string, email: string) => {
    setIsLoading(true);
    try {
      const resp = await request<{
        access_token: string;
        refresh_token: string;
        user: { uuid: string; primaryEmail: string };
      }>("/v1/auth/authenticate", {
        method: "POST",
        body: JSON.stringify({ provider, provider_id: providerId, provider_email: email }),
      });

      setAccessToken(resp.access_token);
      localStorage.setItem(TOKEN_KEY, resp.refresh_token);
      setUser({
        id: resp.user.uuid,
        name: "",
        email: resp.user.primaryEmail || email,
      });
    } finally {
      setIsLoading(false);
    }
  }, []);

  const signup = useCallback(async (provider: string, providerId: string, email: string, profile?: Record<string, string>) => {
    setIsLoading(true);
    try {
      const resp = await request<{
        access_token: string;
        refresh_token: string;
        user: { uuid: string; primaryEmail: string };
      }>("/v1/auth/authenticate", {
        method: "POST",
        body: JSON.stringify({
          provider,
          provider_id: providerId,
          provider_email: email,
          profile: profile || {},
        }),
      });

      setAccessToken(resp.access_token);
      localStorage.setItem(TOKEN_KEY, resp.refresh_token);
      setUser({
        id: resp.user.uuid,
        name: profile?.name || "",
        email: resp.user.primaryEmail || email,
      });
    } finally {
      setIsLoading(false);
    }
  }, []);

  const logout = useCallback(async () => {
    const refreshToken = localStorage.getItem(TOKEN_KEY);
    if (refreshToken) {
      try {
        await request("/v1/auth/logout", {
          method: "POST",
          body: JSON.stringify({ refresh_token: refreshToken }),
        });
      } catch {}
    }
    localStorage.removeItem(TOKEN_KEY);
    setAccessToken(null);
    setUser(null);
  }, []);

  return (
    <AuthContext value={{
      user,
      isLoading,
      isAuthenticated: !!accessToken,
      login,
      signup,
      logout,
      accessToken,
    }}>
      {children}
    </AuthContext>
  );
}

export function useAuth() {
  const context = useContext(AuthContext);
  if (!context) {
    throw new Error("useAuth must be used within an AuthProvider");
  }
  return context;
}
{{- end }}
