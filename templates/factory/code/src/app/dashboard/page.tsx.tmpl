      </defs>
      <path
        d={`${path} L100,32 L0,32 Z`}
        fill={`url(#grad-${color})`}
      />
      <path
        d={path}
        fill="none"
        stroke={color}
        strokeWidth="2"
        vectorEffect="non-scaling-stroke"
      />
    </svg>
  );
}

