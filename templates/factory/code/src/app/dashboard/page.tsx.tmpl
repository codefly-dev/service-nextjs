            </Card>
            <Card>
              <CardHeader className="pb-2">
                <CardTitle className="text-sm font-medium text-muted-foreground">
                  Revenue
                </CardTitle>
              </CardHeader>
              <CardContent>
                <div className="text-3xl font-bold">$45,678</div>
                <p className="mt-1 text-xs text-emerald-500 font-medium">
                  +8% from last month
                </p>
                <Sparkline
                  path="M0,20 L10,22 L20,18 L30,15 L40,17 L50,12 L60,14 L70,8 L80,10 L90,6 L100,3"
