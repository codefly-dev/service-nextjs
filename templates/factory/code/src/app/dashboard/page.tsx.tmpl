function Sparkline({ path, color }: { path: string; color: string }) {
  return (
    <svg
      viewBox="0 0 100 32"
      className="h-8 w-full mt-3"
      preserveAspectRatio="none"
    >
      <defs>
        <linearGradient id={`grad-${color}`} x1="0" y1="0" x2="0" y2="1">
          <stop offset="0%" stopColor={color} stopOpacity="0.2" />
